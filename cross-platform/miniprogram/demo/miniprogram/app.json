{
  "pages": [
    "pages/home/index",
    "pages/app/index",
    "pages/chat/index",
    "pages/user/index",
    "pages/left/index",
    "pages/mid/index",
    "pages/right/index",
    "pages/base/base",
    "pages/wxml/index",
    "pages/app/event/index",
    "pages/app/safe-area/index",
    "pages/app/webview/index",
    "pages/app/choose-media/index",
    "pages/app/canvas/index",
    "pages/app/download-file-open-document/index",
    "pages/app/preview-image/index",
    "pages/app/request/index",
    "pages/app/sass/index",
    "pages/app/component/index",
    "pages/app/select-component/index",
    "pages/app/login/index",
    "pages/app/get-device-info/index",
    "pages/app/page-style/index",
    "pages/app/keep-state/index",
    "pages/app/input/index",
    "pages/app/checkbox/index",
    "pages/app/bluetooth/index",
    "pages/chat/test/index"
  ],
  "window": {
    "navigationBarTextStyle": "black",
    "navigationStyle": "custom",
    "navigationBarTitleText": "测试",
    "navigationBarBackgroundColor": "#123333"
  },
  "renderer": "webview",
  "rendererOptions": {
    "skyline": {
      "defaultDisplayBlock": true,
      "defaultContentBox": true,
      "disableABTest": true,
      "sdkVersionBegin": "3.0.0",
      "sdkVersionEnd": "15.255.255"
    }
  },
  "componentFramework": "glass-easel",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "tabBar": {
    "custom": true,
    "list": [
      {
        "text": "home",
        "pagePath": "pages/home/index"
      },
      {
        "text": "app",
        "pagePath": "pages/app/index"
      },
      {
        "text": "chat",
        "pagePath": "pages/chat/index"
      },
      {
        "text": "user",
        "pagePath": "pages/user/index"
      }
    ]
  },
  "resolveAlias": {
    "@/*": "/*"
  }
}